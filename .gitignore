# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Environment
.env.local
.env*.local

# vercel
.vercel

# Output files (generated content - not committed)
output/*.json
output/*.md
output/*.html
output/*.mdx

# Input files with real content (keep only examples)
input/new-blog.json
input/existing-blog.md
input/optimize-config.json

# typescript
*.tsbuildinfo
next-env.d.ts

# OS
Thumbs.db
