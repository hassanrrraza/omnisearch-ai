GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
MAX_BLOG_WORDS=2500

# Public site URL used for canonical links, sitemap, Open Graph, and JSON-LD.
# Set this to your production domain before deploying (no trailing slash).
# Example: https://omnisearch-ai.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
